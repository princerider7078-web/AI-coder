# ============================================================================
# GrowPlants — Server-Side Environment Variables
# Source: 04_environment_and_configs.md §1
# Copy this file to ".env" and fill in real values. NEVER commit .env.
# ============================================================================

# PostgreSQL database URL (Neon, RDS, or local Postgres)
# Phase 1 sandbox uses SQLite — set to "file:./dev.db" until PostgreSQL is provisioned.
DATABASE_URL="file:./dev.db"

# JWT secrets for HTTP-only session cookies
JWT_SECRET="growplants-super-secret-jwt-key-change-in-production"
JWT_REFRESH_SECRET="growplants-super-secret-refresh-jwt-key-change-in-production"

# Public app URL (used for SEO, OG tags, sitemap)
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# Node environment
NODE_ENV="development"

# Razorpay (Phase 10 — Checkout)
RAZORPAY_KEY_ID=""
RAZORPAY_KEY_SECRET=""
RAZORPAY_WEBHOOK_SECRET=""

# SMS (Phase 5+ — OTP, notifications)
MSG91_AUTH_KEY=""
MSG91_SENDER_ID="GRWPLT"

# Email (Phase 5+ — registration, invoices, booking confirmations)
SENDGRID_API_KEY=""

# Maps (Phase 7+ — pincode picker, address map)
GOOGLE_MAPS_API_KEY=""

# Storage (optional — Firebase Storage is the default)
AWS_ACCESS_KEY_ID=""
AWS_SECRET_ACCESS_KEY=""
AWS_S3_BUCKET="growplants-media"
AWS_REGION="ap-south-1"
